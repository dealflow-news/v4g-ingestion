# ═══════════════════════════════════════════════════════════════════════════
# V4G Ingestion — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in real values. .env is gitignored.
# In production (Render), these are set via the dashboard per service.

# ─── Supabase ──────────────────────────────────────────────────────────────
# Golden Safe project. Same across all V4G tools.
SUPABASE_URL=https://rirkgpsdcaxnowwmliof.supabase.co

# Anonymous key — safe to use client-side with RLS.
SUPABASE_ANON_KEY=eyJ...  # paste anon JWT

# Service role — server-side only. BYPASSES RLS. Never expose to browsers.
# This is what writers use to insert into fact_financials etc.
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # paste service_role JWT

# ─── KBO Proxy (Supabase Edge Function) ────────────────────────────────────
# Path appended to SUPABASE_URL. Default assumes the existing deployed proxy.
KBO_PROXY_PATH=/functions/v1/kbo-proxy

# ─── NBB CBSO (Belgian Central Balance Sheet) ──────────────────────────────
# Your "Authentic Data" subscription key. Used by domain/nbb/fetcher.py.
NBB_API_KEY=

# ─── Runtime ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
FLASK_DEBUG=0

# Worker
WORKER_MODE=continuous            # continuous | oneshot
POLL_INTERVAL_SECONDS=30
WORKER_BATCH_SIZE=10
WORKER_MAX_ATTEMPTS=3

# Cache (local dev only — Render uses ephemeral filesystem)
CACHE_DIR=./cache
USE_CACHE=1
