# ═══════════════════════════════════════════════════════════════════════════
# Python
# ═══════════════════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ═══════════════════════════════════════════════════════════════════════════
# Virtual environments
# ═══════════════════════════════════════════════════════════════════════════
.venv/
venv/
env/
ENV/

# ═══════════════════════════════════════════════════════════════════════════
# Tooling caches
# ═══════════════════════════════════════════════════════════════════════════
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# ═══════════════════════════════════════════════════════════════════════════
# Secrets — NEVER commit
# ═══════════════════════════════════════════════════════════════════════════
.env
.env.*
!.env.example
config.json
*.pem
*.key

# ═══════════════════════════════════════════════════════════════════════════
# Build artifacts
# ═══════════════════════════════════════════════════════════════════════════
output/
cache/
*.log

# ═══════════════════════════════════════════════════════════════════════════
# Editors / OS
# ═══════════════════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ═══════════════════════════════════════════════════════════════════════════
# Data files — add exceptions under tests/fixtures/ if needed
# ═══════════════════════════════════════════════════════════════════════════
*.xlsx
*.xlsb
*.csv
*.zip
!tests/fixtures/**
